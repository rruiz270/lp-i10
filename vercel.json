  "redirects": [
    { "source": "/siteteste", "destination": "/siteteste/", "permanent": false },
    { "source": "/better-financeiro", "destination": "/better-financeiro/", "permanent": false },
    { "source": "/fundeb", "destination": "/fundeb-hub.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/apm-lp(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
