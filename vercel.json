    { "source": "/fundeb-al", "destination": "/fundeb-estado.html?uf=al" },
    { "source": "/fundeb-am", "destination": "/fundeb-estado.html?uf=am" },
    { "source": "/fundeb-ap", "destination": "/fundeb-estado.html?uf=ap" },
    { "source": "/fundeb-ba", "destination": "/fundeb-estado.html?uf=ba" },
    { "source": "/fundeb-ce", "destination": "/fundeb-estado.html?uf=ce" },
