    { "source": "/fundeb-go", "destination": "/fundeb-estado.html?uf=go" },
    { "source": "/fundeb-ma", "destination": "/fundeb-estado.html?uf=ma" },
    { "source": "/fundeb-mg", "destination": "/fundeb-estado.html?uf=mg" },
    { "source": "/fundeb-ms", "destination": "/fundeb-estado.html?uf=ms" },
    { "source": "/fundeb-mt", "destination": "/fundeb-estado.html?uf=mt" },
    { "source": "/fundeb-pa", "destination": "/fundeb-estado.html?uf=pa" },
    { "source": "/fundeb-pb", "destination": "/fundeb-estado.html?uf=pb" },
    { "source": "/fundeb-pe", "destination": "/fundeb-estado.html?uf=pe" },
    { "source": "/fundeb-pi", "destination": "/fundeb-estado.html?uf=pi" },
    { "source": "/fundeb-pr", "destination": "/fundeb-estado.html?uf=pr" },
