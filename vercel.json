    {
      "source": "/materiais-bncc",
      "destination": "https://bncc-computacao.vercel.app/pos-webinar"
    },
    {
      "source": "/api/pos-webinar",
      "destination": "https://bncc-computacao.vercel.app/api/pos-webinar"
    },
