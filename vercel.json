    },
    {
      "source": "/sistemas/apm/api/:path*",
      "destination": "https://apm-seven.vercel.app/api/:path*"
    },
    {
      "source": "/apm-lp",
      "destination": "/apm-lp/index.html"
    },
    {
      "source": "/apm-fundeb",
      "destination": "https://webinar-fundeb-apm.vercel.app/"
    },
    {
      "source": "/apm-fundeb/:path*",
      "destination": "https://webinar-fundeb-apm.vercel.app/:path*"
